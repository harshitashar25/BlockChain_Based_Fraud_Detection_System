# Example Corda Node Configuration
# Copy this to your node's directory and customize

# Node identity
myLegalName="O=BankA,L=London,C=GB"

# Network settings
p2pAddress="localhost:10002"
rpcSettings {
    address="localhost:10006"
    adminAddress="localhost:10046"
}

# RPC users
rpcUsers=[
    {
        username=user1
        password=test
        permissions=[
            ALL
        ]
    }
]

# Notary (if this node is a notary)
# notary {
#     validating=false
# }

# Cordapps
cordapps = []

# Database (optional - uses H2 by default)
# dataSourceProperties {
#     dataSource {
#         url="jdbc:h2:file:./persistence.mv.db"
#     }
#     database {
#         transactionIsolationLevel=READ_COMMITTED
#     }
# }

# Logging
loggingLevel=INFO

# Development mode (set to false in production)
devMode=true

# Example for BankB:
# myLegalName="O=BankB,L=New York,C=US"
# p2pAddress="localhost:10005"
# rpcSettings {
#     address="localhost:10009"
#     adminAddress="localhost:10049"
# }

